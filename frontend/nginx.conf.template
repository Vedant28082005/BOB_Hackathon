# HTTP server (port 80). Kept serving so Cloudflare Flexible mode and plain
# HTTP keep working; HTTPS is added by ssl.conf when an origin cert is present.
server {
    listen ${NGINX_PORT};
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    include /etc/nginx/app_locations.inc;

    client_max_body_size 20M;

    gzip on;
    gzip_types text/plain application/javascript application/json text/css;
}
