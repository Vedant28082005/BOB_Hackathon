# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://trustlayer:trustlayer_pg@postgres:5432/trustlayer

# ── Neo4j ────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── Redis / Celery ───────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── MinIO ────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=trustlayer
MINIO_SECRET_KEY=your_minio_secret
MINIO_BUCKET=trustlayer-media
MINIO_SECURE=false

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AES encryption ───────────────────────────────────────
AES_KEY_HEX=your_64_char_hex_aes_key

# ── ML service ───────────────────────────────────────────
ML_SERVICE_URL=http://ml-service:8001
INTERNAL_API_KEY=your_internal_api_key
ML_TIMEOUT_SECONDS=120

# ── GPU ──────────────────────────────────────────────────
USE_GPU=false

# ── LLM ──────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Trust scoring weights ────────────────────────────────
WEIGHT_DOCUMENT=0.30
WEIGHT_BIOMETRIC=0.35
WEIGHT_DEVICE=0.10
WEIGHT_BEHAVIOURAL=0.10
WEIGHT_IDENTITY_GRAPH=0.15
THRESHOLD_APPROVE=75
THRESHOLD_STEP_UP=50
THRESHOLD_MANUAL_REVIEW=30
