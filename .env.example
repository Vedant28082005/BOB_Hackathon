# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=trustlayer
POSTGRES_PASSWORD=CHANGE_ME_strong_pg_password
POSTGRES_DB=trustlayer
DATABASE_URL=postgresql+asyncpg://trustlayer:CHANGE_ME_strong_pg_password@postgres:5432/trustlayer

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_redis_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_redis_password@redis:6379/2

# ── Neo4j ─────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j_password

# ── MinIO ─────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_user
MINIO_SECRET_KEY=CHANGE_ME_minio_password_min12chars
MINIO_BUCKET=trustlayer-kyc
MINIO_SECURE=false

# ── Auth ──────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
AES_KEY_HEX=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Internal API ──────────────────────────────────────────
# Generate: openssl rand -hex 16
INTERNAL_API_KEY=CHANGE_ME_internal_api_key

# ── LLM ───────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
